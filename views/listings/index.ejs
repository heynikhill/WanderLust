        .filterDiv{
            display:flex;
            flex-direction:inline;
        }
         #filters {
            display: flex;
            flex-wrap: nowrap; /* Prevent wrapping */
            overflow-x: auto;  /* Enable horizontal scroll */
            width: 75%;        /* 60–65% width of page */
            margin: 1rem ; /* Center it horizontally */
            padding: 0.5rem 1rem;
            border: 1px solid #ccc;        /* Add a visible light gray border */
            border-radius: 20px;           /* Makes the border look oval/rounded */
            background-color: #f9f9f9;     /* Optional: light background to highlight box */
            gap: 1rem;
            scrollbar-width: thin; /* For Firefox */
            box-sizing: border-box;        /* Ensures padding doesn't expand the border */
            scrollbar-gutter: stable both-edges; /* Prevent scrollbar from overlapping */
            scroll-padding: 0.5rem;        /* Optional: keeps some space while scrolling */
        }

        /* Optional: style scrollbar for Webkit browsers */
        #filters::-webkit-scrollbar {
            height: 6px;
        }
        #filters::-webkit-scrollbar-thumb {
            background: #bbb;
            border-radius: 10px;
        }

        /* Individual filter items */
        .filter {
             text-decoration: none;
            color: black; /* 👈 This sets text and icon color to black */
            flex: 0 0 auto; /* Prevent shrinking */
            text-align: center;
            opacity: 0.7;
            transition: opacity 0.3s ease;
            cursor: pointer;
        }

        .filter:hover {
            opacity: 1;
            color: black; /* 👈 Keeps hover color black as well */
        }

        .filter i {
            font-size: 1.5rem;
            color: black;/* 👈 Icon color */
            transition: color 0.3s ease;
        }

        .filter:hover i {
            color: #000;
        }

        .filter p {
            font-size: 0.8rem;
            margin: 0.3rem 0 0;
        }
        .ToogleSwitch{
            margin:25px;
            border:2px solid black;
            border-radius:10px;
            padding:5px;
        }

        .form-check-label{
            font-size:large;
            margin-right:15px;
            padding-right:15px;
        }
       
        .tax-info{
            display:none;
        }
        /* .ToogleSwitch{
            border:1p
        } */
     </style>
